# =============================================================================
# PHP Sandbox – Deployment Environment Template
# Copy this to .env on your server and fill in the values marked with <CHANGE>
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="PHP Sandbox"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://<YOUR_SERVER_IP_OR_DOMAIN>

# Generate with: php artisan key:generate --show
# OR leave blank — the container will auto-generate on first start
APP_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DB_DATABASE=phpsandbox
DB_USERNAME=phpsandbox_app
DB_PASSWORD=<CHANGE_ME_strong_db_password>
MYSQL_ROOT_PASSWORD=<CHANGE_ME_strong_root_password>

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<CHANGE_ME_strong_redis_password>

# ── Sandbox Service ──────────────────────────────────────────────────────────
SANDBOX_SECRET=<CHANGE_ME_random_32_char_string>
SANDBOX_DB_ADMIN_USER=sandbox_admin
SANDBOX_DB_ADMIN_PASS=<CHANGE_ME_sandbox_admin_password>
SANDBOX_MAX_EXECUTION_TIME=5
SANDBOX_MEMORY_LIMIT_MB=64

# ── Mail (optional — defaults to internal mailpit for dev) ────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=noreply@phpsandbox.local
MAIL_FROM_NAME="PHP Sandbox"

# ── Docker Hub (set to your Docker Hub username) ─────────────────────────────
DOCKER_USER=phpsandbox
TAG=latest

# ── Server port ───────────────────────────────────────────────────────────────
HTTP_PORT=80

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=error
