[mysqld]
# Connection tuning for 80 concurrent users
max_connections        = 200
max_allowed_packet     = 64M
wait_timeout           = 600
interactive_timeout    = 600

# InnoDB buffer — allocate ~60% of available DB container memory
innodb_buffer_pool_size    = 512M
innodb_buffer_pool_instances = 2
innodb_log_file_size       = 128M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method        = O_DIRECT

# Query cache (disabled in MySQL 8, use Redis instead)
# Performance schema (disable if not needed)
performance_schema = OFF

# Slow query logging — helps identify future bottlenecks
slow_query_log        = 1
slow_query_log_file   = /var/lib/mysql/slow.log
long_query_time       = 1

[client]
default-character-set = utf8mb4
